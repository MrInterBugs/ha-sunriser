FROM python:3.13-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir mkdocs mkdocs-material mkdocstrings[python] mkdocs-macros-plugin

COPY custom_components/ custom_components/
COPY docs/ docs/
COPY mkdocs.yml .
COPY docs_macros.py .

EXPOSE 8000

CMD ["mkdocs", "serve", "--dev-addr=0.0.0.0:8000"]
